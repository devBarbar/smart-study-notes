{
  "cli": {
    "version": ">= 16.28.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "channel": "development",
      "environment": "development",
      "distribution": "internal"
    },
    "preview": {
      "channel": "preview",
      "environment": "preview",
      "distribution": "internal"
    },
    "simulator": {
      "channel": "development",
      "environment": "development",
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "production": {
      "channel": "production",
      "environment": "production",
      "autoIncrement": true,

      "android": {
        "image": "latest"
      },
      "ios": {
        "image": "latest"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6756254866"
      }
    }
  }
}
